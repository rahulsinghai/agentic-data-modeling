{{- "{{" }} config(
    materialized='{{ model.materialization.value }}'
    {%- if model.tags %},
    tags={{ model.tags }}
    {%- endif %}
) {{ "}}" }}

with source as (
    select * from {{ "{{" }} source('{{ model.depends_on[0] if model.depends_on else "raw" }}', '{{ model.name.replace("stg_", "") }}') {{ "}}" }}
),

renamed as (
    select
        {% for col in model.columns -%}
        {{ col.name }}{% if not loop.last %},{% endif %}
        {% endfor -%}
    from source
)

select * from renamed
