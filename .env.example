# ── OpenAI (default provider) ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ADM_MODEL=gpt-4o-mini

# ── Ollama (local, no API key needed) ────────────────────────────────────────
# Uncomment the lines below and set ADM_PROVIDER=ollama to use a local model.
# ADM_PROVIDER=ollama
# ADM_OLLAMA_MODEL=llama3.2
# ADM_OLLAMA_BASE_URL=http://localhost:11434

# ── Shared ────────────────────────────────────────────────────────────────────
ADM_OUTPUT_DIR=output
